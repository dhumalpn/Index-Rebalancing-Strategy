# Index Rebalancing Strategy — Full Pipeline

This notebook runs the full pipeline:
1. Load data
2. Generate signals
3. Run backtest
4. Evaluate performance
5. Risk & ML insights

from src.data_loader import *
from src.signal_generator import *
from src.backtest_engine import *
from src.metrics import *
from src.ml_model import *

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# Load event data
events = pd.read_csv("../data/sp500_changes.csv")

# Clean
events = events.dropna(subset=["announcement_date", "effective_date"])

print("Total events:", len(events))
events.head()

signals = generate_signals(events)

print("Total signals:", len(signals))
signals[:5]

price_data = {}

for s in signals:
    ticker = s["ticker"]
    try:
        price_data[ticker] = get_event_window_data(
            ticker,
            s["announcement_date"]
        )
    except:
        continue

print("Price data loaded for:", len(price_data), "tickers")

results = run_backtest(signals, price_data)

print("Total trades:", len(results))
results.head()

sharpe = sharpe_ratio(results["return"])
win = win_rate(results["return"])

print("Sharpe Ratio:", sharpe)
print("Win Rate:", win)

equity_curve = (1 + results["return"]).cumprod()

plt.figure()
plt.plot(equity_curve)
plt.title("Equity Curve")
plt.xlabel("Trades")
plt.ylabel("Portfolio Value")
plt.show()

peak = np.maximum.accumulate(equity_curve)
drawdown = (equity_curve - peak) / peak

plt.figure()
plt.plot(drawdown)
plt.title("Drawdown")
plt.show()

print("Max Drawdown:", max_drawdown(equity_curve))

results["type"] = results["direction"].apply(lambda x: "Addition" if x == 1 else "Removal")

grouped = results.groupby("type")["return"].mean()

print(grouped)

grouped.plot(kind="bar", title="Additions vs Removals")
plt.show()

